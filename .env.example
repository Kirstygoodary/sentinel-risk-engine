# Copy to .env. Matches docker-compose.yml (Postgres on host port 5433).
DATABASE_URL="postgresql://risk:risk@localhost:5433/risk_engine?schema=public"

# Engine posture. SHADOW = score everything, act on nothing (safe default /
# calibration phase). Set to "false" to let the engine enforce holds/pauses.
RISK_SHADOW_MODE=true

# [fill: any thresholds you choose to make tunable via env rather than hardcode —
# e.g. RISK_GUARDRAIL_LOSS_THRESHOLD, RISK_MAD_FLOOR. Re-derive your own values.]
